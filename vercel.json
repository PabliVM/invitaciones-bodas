{
  "rewrites": [
    { "source": "/editor", "destination": "/editor.html" },
    { "source": "/invitation", "destination": "/invitation.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
